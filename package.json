{
  "name": "pr-readiness-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Automated PR readiness analysis tool",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:watch": "npm run test:watch -w @pr-ready/cli",
    "test:coverage": "jest --coverage",
    "dev": "npm run dev -w @pr-ready/cli",
    "prepare": "husky install",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.4",
    "memfs": "^4.57.2",
    "nock": "^14.0.15",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
