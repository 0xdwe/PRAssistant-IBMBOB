{
  "$schema": "../packages/shared/src/config-schema.json",
  "llm": {
    "provider": "openai",
    "apiKey": "${OPENAI_API_KEY}",
    "model": "gpt-4",
    "temperature": 0.3,
    "maxTokens": 2000
  },
  "output": {
    "file": ".pr-ready.md",
    "clipboard": true
  },
  "test": {
    "command": "npm test",
    "timeout": 300000,
    "patterns": [
      "**/*.test.ts",
      "**/*.spec.ts"
    ]
  },
  "risks": {
    "patterns": [
      "**/migrations/**",
      "**/auth/**",
      "**/*.config.js",
      "**/*.config.ts",
      "**/package.json"
    ]
  },
  "cache": {
    "enabled": true,
    "ttl": 3600
  }
}