{
  "$schema": "../packages/shared/src/config-schema.json",
  "llm": {
    "provider": "none"
  },
  "monorepo": {
    "enabled": true,
    "type": "auto",
    "packagePaths": [
      "packages/*",
      "apps/*"
    ],
    "rootFiles": [
      "package.json",
      "lerna.json",
      "pnpm-workspace.yaml",
      "nx.json"
    ]
  },
  "output": {
    "file": ".pr-ready.md",
    "clipboard": true
  },
  "test": {
    "command": "npm test --workspaces",
    "timeout": 600000,
    "patterns": [
      "**/*.test.ts",
      "**/*.spec.ts"
    ]
  },
  "risks": {
    "patterns": [
      "**/migrations/**",
      "**/auth/**",
      "**/*.config.js",
      "**/*.config.ts",
      "**/package.json",
      "**/package-lock.json",
      "**/pnpm-lock.yaml",
      "**/yarn.lock"
    ]
  }
}