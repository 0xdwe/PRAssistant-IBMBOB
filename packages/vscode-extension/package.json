{
  "name": "pr-ready-vscode",
  "displayName": "PR Ready Assistant",
  "description": "Automated PR readiness analysis with LLM support",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:prReady.analyze"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prReady.analyze",
        "title": "PR Ready: Analyze Current Branch"
      }
    ],
    "configuration": {
      "title": "PR Ready",
      "properties": {
        "prReady.llm.provider": {
          "type": "string",
          "enum": ["openai", "anthropic", "ollama", "none"],
          "default": "openai",
          "description": "LLM provider to use for analysis"
        },
        "prReady.llm.baseURL": {
          "type": "string",
          "default": "http://172.16.6.27:20128/v1",
          "description": "Custom base URL for LLM API"
        },
        "prReady.llm.model": {
          "type": "string",
          "default": "kr/claude-sonnet-4.5",
          "description": "Model to use for analysis"
        },
        "prReady.llm.apiKey": {
          "type": "string",
          "default": "sk-19d8880ef9d5cdc5-9r6vgy-a9b2b4cd",
          "description": "API key for LLM provider"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "dependencies": {
    "@pr-ready/cli": "^0.1.0",
    "@pr-ready/shared": "^0.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}