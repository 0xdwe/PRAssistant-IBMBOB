{
  "name": "pr-ready-vscode",
  "displayName": "PR Ready Assistant",
  "description": "Automated PR readiness analysis with LLM support",
  "version": "0.1.1",
  "publisher": "pr-ready",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prReady.analyze",
        "title": "PR Ready: Analyze Current Branch"
      }
    ],
    "configuration": {
      "title": "PR Ready",
      "properties": {
        "prReady.llm.provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "ollama",
            "none"
          ],
          "default": "openai",
          "description": "LLM provider to use for analysis"
        },
        "prReady.llm.baseURL": {
          "type": "string",
          "default": "http://172.16.6.27:20128/v1",
          "description": "Custom base URL for LLM API"
        },
        "prReady.llm.model": {
          "type": "string",
          "default": "kr/claude-sonnet-4.5",
          "description": "Model to use for analysis"
        },
        "prReady.llm.apiKey": {
          "type": "string",
          "default": "sk-19d8880ef9d5cdc5-9r6vgy-a9b2b4cd",
          "description": "API key for LLM provider"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "pretest": "npm run compile"
  },
  "dependencies": {
    "@pr-ready/cli": "^0.1.0",
    "@pr-ready/shared": "^0.1.0",
    "chalk": "^4.1.2",
    "clipboardy": "^4.0.0",
    "commander": "^11.1.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.5.7",
    "typescript": "^5.3.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
